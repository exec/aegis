build/
kernel/cap/target/
/tmp/aegis_serial.txt
*.o
*.elf
.worktrees/
reference/

# musl build artifacts — NEVER track these.
# A stale config.mak (e.g., from macOS ARM) silently builds ARM musl
# on x86 servers, producing broken userspace binaries.
references/rune/
references/musl-*/config.mak
references/musl-*/obj/
references/musl-*/lib/
kernel/*_bin.c
kernel/*_blob.c
.init_stamp_*

# User-space built binaries — NEVER track these.
# The stale-binary catastrophe of 2026-03-28 was caused by git-tracked
# vigil/vigictl binaries surviving make clean and git checkout.
user/vigil/vigil
user/vigictl/vigictl
user/dhcp/dhcp
user/chronos/chronos
user/lumen/lumen
user/httpd/httpd
user/installer/installer
user/login/login.elf
user/fb_test/fb_test
user/mouse_test/mouse_test
user/thread_test/thread_test
user/mmap_test/mmap_test
user/proc_test/proc_test
user/pty_test/pty_test
user/dynlink_test/dynlink_test
tests/target/

# Test artifacts — screendumps change with every UI tweak and are
# regenerated by the test suite. Keep .gitkeep to preserve the dir.
tests/screenshots/*.ppm
tests/screenshots/*.png
user/bin/rune
